# ===== CONFIGURAÇÃO BLING =====
BLING_API_URL=https://bling.com.br/Api/v2
BLING_API_KEY=sua_chave_api_bling_aqui

# ===== CONFIGURAÇÃO DECISOR =====
DECISOR_API_URL=http://localhost:3004
DECISOR_TIMEOUT=30000

# ===== CONFIGURAÇÃO ATLAS =====
ATLAS_API_URL=http://localhost:3002
ATLAS_TIMEOUT=30000

# ===== CONFIGURAÇÃO AMANDA =====
AMANDA_API_URL=http://localhost:3001
AMANDA_TIMEOUT=30000

# ===== CONFIGURAÇÃO MOCK API =====
MOCK_API_URL=http://localhost:3003
MOCK_API_TIMEOUT=30000

# ===== CONFIGURAÇÃO SERVIDOR =====
BLINGBOT_PORT=3005
BLINGBOT_HOST=0.0.0.0
NODE_ENV=development

# ===== CONFIGURAÇÃO LOG =====
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== CONFIGURAÇÃO PROPOSTA =====
PROPOSTA_PREFIX=PROP
PROPOSTA_MULTIPLICADOR_PRECO=1.6
PROPOSTA_DIAS_ENTREGA=7