{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Proposta Comercial Schema",
  "description": "Schema para validar propostas comerciais",
  "properties": {
    "nome": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Nome do cliente"
    },
    "documento": {
      "type": "string",
      "pattern": "^[0-9]{11}$",
      "description": "CPF ou CNPJ do cliente (apenas números)"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email do cliente"
    },
    "quantidade": {
      "type": "integer",
      "minimum": 1,
      "description": "Quantidade do produto"
    },
    "valor": {
      "type": "number",
      "minimum": 0.01,
      "description": "Valor unitário do produto"
    },
    "descricao": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Descrição do produto"
    },
    "endereco": {
      "type": "string",
      "minLength": 1,
      "description": "Endereço do cliente"
    },
    "telefone": {
      "type": "string",
      "pattern": "^\d{10,11}$",
      "description": "Telefone do cliente (10 ou 11 dígitos)"
    },
    "entrega": {
      "type": "string",
      "enum": ["correios", "sedex", "pac", "retirada", "Entrega"],
      "description": "Forma de entrega"
    }
  },
  "required": ["nome", "documento", "email", "quantidade", "valor", "descricao", "endereco", "telefone"],
  "additionalProperties": false
}