# ===== CONFIGURAÇÃO ATLAS =====
ATLAS_PORT=3002
ATLAS_HOST=0.0.0.0

# ===== CONFIGURAÇÃO DECISOR =====
DECISOR_API_URL=http://localhost:3004
DECISOR_TIMEOUT=30000

# ===== CONFIGURAÇÃO AMANDA =====
AMANDA_API_URL=http://localhost:3001
AMANDA_TIMEOUT=30000

# ===== CONFIGURAÇÃO MOCK API =====
MOCK_API_URL=http://localhost:3003
MOCK_API_TIMEOUT=30000

# ===== CONFIGURAÇÃO SERVIDOR =====
NODE_ENV=development
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== CONFIGURAÇÃO BANCO DE DADOS =====
# Em produção, seria um banco real (PostgreSQL, MongoDB, etc)
# Por enquanto usamos memória (não persiste)
DATABASE_TYPE=memory

# ===== VALIDAÇÃO DE DADOS =====
VALIDAR_DOCUMENTO=true
VALIDAR_EMAIL=true
VALIDAR_NOME=true